    {
      "id": "R-ATTN-01",
      "kind": "requirement",
      "label": "rank sessions that need the human"
    },
    {
      "id": "R-ATTN-01-AC1",
      "kind": "acceptanceCriterion",
      "label": "WHEN scoring a session that is blocked on the human THEN the system SHALL return a priority of 5 for WaitingApproval, 4 for NeedsInput, 3 for Error, and 2 for an unseen Done — so the Attention Dock sorts the most urgent first."
    },
    {
      "id": "test:regatta_core::attention::tests::ranks_blocked_sessions",
      "kind": "test",
      "label": "regatta_core::attention::tests::ranks_blocked_sessions",
      "meta": {
        "kind": "unit"
      }
    },
    {
      "id": "R-ATTN-01-AC2",
      "kind": "acceptanceCriterion",
      "label": "IF a session is actively working or transitional (Starting, Running, Compacting, RateLimited, Paused) THEN the system SHALL return a priority of 0 so it never surfaces in the Attention Dock."
    },
    {
      "id": "test:regatta_core::attention::tests::working_sessions_score_zero",
